VITE_AUTHENTICATION_MODE=legacy_session
VITE_API_BASE_URL=
VITE_API_DISPLAY_URL=http://localhost:8081
VITE_API_PROXY_TARGET=http://localhost:8081

# Local development Keycloak public-client settings.
# Used only when VITE_AUTHENTICATION_MODE=keycloak_jwt.
# Do not add client secrets, admin credentials, tokens, passwords, or user credentials here.
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=workspace-dev
VITE_KEYCLOAK_CLIENT_ID=workspace-web
